download/

# Upload directory (local dev only — anchored to root so src/app/upload/ is NOT excluded)
/upload/

# Skills reference directory (not part of the app)
skills/

# Documentation (keep README)
*.md
!README.md

# Database
db/

# IDE / OS
.git/
.gitignore
.eslintrc*

# Lockfiles (Vercel regenerates these)
bun.lock

# Subagent artifacts
tool-results/
