# ============================================================
#  Polio Campaign Dashboard — Environment Variables
#  Copy this file to `.env.local` and fill in real values.
#  (`.env.local` is gitignored and never committed.)
# ============================================================

# ---- Supabase ----
# Project URL: found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# anon key (safe for browser). Project Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLIC-KEY

# service_role key (SERVER ONLY — never expose to the browser).
# Used in trusted server routes / cron jobs that bypass RLS.
# Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY

# ---- Groq AI ----
# Console: https://console.groq.com/keys
GROQ_API_KEY=YOUR-GROQ-API-KEY

# Model id used for insight generation (LLaMA-3.3-70B recommended)
GROQ_MODEL=llama-3.3-70b-versatile
